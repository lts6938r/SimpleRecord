<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <!-- Allow cleartext traffic to your specific local IP address range -->
        <!-- REPLACE 192.168.1.0/24 with your actual local network range or specific IP -->
        <!-- If your backend IP is 192.168.1.100, use 192.168.1.0/24 or the specific IP -->
        <domain includeSubdomains="true">192.168.123.127</domain> <!-- Replace with your PC's LAN IP -->
        <domain includeSubdomains="true">10.0.2.2</domain>    <!-- For Android Emulator loopback to host PC -->
        <domain includeSubdomains="true">10.0.3.2</domain>    <!-- For Genymotion Emulator loopback to host PC -->
    </domain-config>
</network-security-config>